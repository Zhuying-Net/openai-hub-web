{
  "name": "openai-hub-web",
  "version": "1.0.0",
  "description": "OpenAI-Hub 官网 - AI API 聚合平台",
  "main": "server/app.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run build:watch\"",
    "server:dev": "nodemon server/app.js",
    "server:start": "node server/app.js",
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "admin": "node server/app.js --admin-only"
  },
  "dependencies": {
    "express": "^4.21.0",
    "better-sqlite3": "^11.6.0",
    "nunjucks": "^3.2.4",
    "marked": "^15.0.0",
    "node-cron": "^3.0.3",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "chokidar": "^4.0.0",
    "glob": "^11.0.0",
    "front-matter": "^4.0.2",
    "feed": "^4.2.2",
    "sitemap": "^8.0.0",
    "lunr": "^2.3.9",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.0"
  }
}
