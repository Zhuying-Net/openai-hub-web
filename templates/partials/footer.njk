<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="brand brand-footer" href="{{ baseUrl }}">
        <span class="brand-mark">OH</span>
        <span class="brand-text">{{ locale.site.name }}</span>
      </a>
      <p class="footer-tagline">{{ locale.footer.tagline }}</p>
    </div>

    <div>
      <h2 class="footer-title">{{ locale.footer.linksTitle }}</h2>
      <ul class="footer-links">
        <li><a href="{{ baseUrl }}">{{ locale.footer.links.home }}</a></li>
        <li><a href="#features">{{ locale.footer.links.features }}</a></li>
        <li><a href="#faq">{{ locale.footer.links.faq }}</a></li>
        <li><a href="https://api.openai-hub.com" target="_blank" rel="noopener noreferrer">{{ locale.footer.links.api }}</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>{{ locale.footer.copyright }}</p>
  </div>
</footer>
