<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="{{ baseUrl }}">
      <span class="brand-mark">OH</span>
      <span class="brand-text">{{ locale.site.name }}</span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#features">{{ locale.nav.features }}</a>
      <a href="#pricing">{{ locale.nav.pricing }}</a>
      <a href="#security">{{ locale.nav.security }}</a>
      <a href="#faq">{{ locale.nav.faq }}</a>
    </nav>

    <div class="header-actions">
      <a class="lang-switch" href="{{ altHref }}" hreflang="{% if lang == 'zh' %}en{% else %}zh-CN{% endif %}">
        {% if lang == 'zh' %}EN{% else %}中文{% endif %}
      </a>
      <button class="theme-toggle" type="button" aria-label="Toggle theme" data-theme-toggle>
        <span class="theme-toggle-icon">◐</span>
      </button>
      <a class="button button-primary button-sm" href="https://api.openai-hub.com" target="_blank" rel="noopener noreferrer">
        {{ locale.nav.cta }}
      </a>
    </div>
  </div>
</header>
