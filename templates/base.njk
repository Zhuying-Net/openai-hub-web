<!DOCTYPE html>
<html lang="{{ locale.site.lang }}" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ locale.site.title }}{% endblock %}</title>
  <meta name="description" content="{% block description %}{{ locale.site.description }}{% endblock %}">
  <meta name="theme-color" content="#0b1020">
  <meta property="og:title" content="{{ locale.site.title }}">
  <meta property="og:description" content="{{ locale.site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.openai-hub.com/">
  <meta property="og:site_name" content="{{ locale.site.name }}">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="canonical" href="https://www.openai-hub.com/{{ pagePath | default('') }}">
  <link rel="preconnect" href="https://api.openai-hub.com">
  <link rel="stylesheet" href="/assets/css/style.css">
  {% if altPath %}
  <link rel="alternate" hreflang="{% if lang == 'zh' %}en{% else %}zh-CN{% endif %}" href="https://www.openai-hub.com/{{ altPath }}">
  {% endif %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "OpenAI-Hub",
      "url": "https://www.openai-hub.com",
      "sameAs": ["https://api.openai-hub.com"],
      "description": "{{ locale.site.description }}"
    }
  </script>
  <!-- 百度统计代码预留位 -->
  <!-- 在此处插入 Baidu Analytics / 百度统计脚本 -->
  {% block head %}{% endblock %}
</head>
<body>
  {% include "partials/header.njk" %}

  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  {% include "partials/footer.njk" %}
  <script src="/assets/js/main.js" defer></script>
  {% block scripts %}{% endblock %}
</body>
</html>
